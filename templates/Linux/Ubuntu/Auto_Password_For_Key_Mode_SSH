config secret template
    edit "Robert_Unix_Key"
        config field
            edit "Host"
                set type target-address
            next
            edit "Username"
                set type username
            next
            edit "Public-key"
                set type public-key
                set mandatory disable
            next
            edit "Private-key"
                set type private-key
                set mandatory disable
                set need-edit enable
            next
            edit "Passphrase"
                set type passphrase
                set mandatory disable
                set need-edit enable
            next
            edit "Password"
                set type password
            next
        end
        config launcher
            edit 1
                set launcher-name "PuTTY"
                set port 22
            next
            edit 2
                set launcher-name "WinSCP"
                set port 22
            next
            edit 3
                set launcher-name "Web SSH"
                set port 22
            next
        end
        config password-changer
            set password-changer-name "SSH Key (Unix)"
        end
        config web-filler
        end
        set server-info Unix-like
    next
end
