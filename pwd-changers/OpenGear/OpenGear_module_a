config secret password-changer
    edit "MIS_SSH_Password(OpenGear)"
        config change
            edit 1
                set type expect-prompt
            next
            edit 2
                set command "passwd"
            next
            edit 3
                set type expect
                set command "password:"
            next
            edit 4
                set command "$PASSWORD"
            next
            edit 5
                set type expect
                set command "password:"
            next
            edit 6
                set command "$NEWPASSWD"
            next
            edit 7
                set type expect
                set command "password:"
            next
            edit 8
                set command "$NEWPASSWD"
            next
            edit 9
                set type expect
                set command "successfully"
            next
            edit 10
                set command "exit"
            next
        end
    next
end
